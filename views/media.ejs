<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media Library | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
            <div class="text-gray-400 text-sm">Media Library</div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-bold text-white">Media Library</h1>
                <p class="text-gray-400 text-sm">View and manage all uploaded images</p>
            </div>
            <div class="text-gray-400 text-sm">
                <%= images.length %> images
            </div>
        </div>

        <% if (images.length > 0) { %>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8 gap-4">
            <% images.forEach(function(img) { %>
            <div class="image-card group relative bg-gray-800 rounded-xl overflow-hidden border border-gray-700 hover:border-teal-500 transition-colors">
                <div class="aspect-square overflow-hidden cursor-pointer" onclick="showImage('<%= img.path %>', '<%= img.filename %>', '<%= img.size %>', '<%= img.location %>')">
                    <img src="<%= img.path %>" alt="<%= img.filename %>" class="w-full h-full object-cover">
                </div>
                <div class="p-2">
                    <p class="text-xs text-gray-400 truncate" title="<%= img.filename %>"><%= img.filename %></p>
                    <p class="text-xs text-gray-500"><%= formatSize(img.size) %></p>
                </div>
                <button onclick="deleteImage('<%= img.filename %>', '<%= img.location %>')" class="absolute top-2 right-2 bg-red-600 hover:bg-red-700 text-white p-1.5 rounded opacity-0 group-hover:opacity-100 transition-opacity" title="Delete">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                </button>
            </div>
            <% }); %>
        </div>
        <% } else { %>
        <div class="bg-gray-800 rounded-xl p-12 text-center border border-gray-700">
            <div class="w-16 h-16 bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
            </div>
            <p class="text-gray-400">No images uploaded yet</p>
        </div>
        <% } %>
    </main>

    <!-- Image Preview Modal -->
    <div id="imageModal" class="fixed inset-0 bg-black/90 z-50 hidden flex items-center justify-center p-4" onclick="closeModal(event)">
        <div class="bg-gray-900 rounded-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
            <div class="p-4 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-white font-semibold" id="modalFilename">Image</h3>
                <button onclick="closeModal()" class="text-gray-400 hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="p-4 overflow-auto max-h-[60vh]">
                <img id="modalImage" src="" alt="" class="w-full rounded-lg">
            </div>
            <div class="p-4 border-t border-gray-800">
                <div class="flex justify-between items-center">
                    <div class="text-sm text-gray-400">
                        <span id="modalSize"></span> | <span id="modalLocation"></span>
                    </div>
                    <button onclick="copyUrl()" class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-lg text-sm">
                        Copy URL
                    </button>
                </div>
                <div class="mt-3">
                    <input type="text" id="imageUrl" readonly class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-300" onclick="this.select()">
                </div>
            </div>
        </div>
    </div>

    <script>
        function formatSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        function showImage(path, filename, size, location) {
            document.getElementById('modalFilename').textContent = filename;
            document.getElementById('modalImage').src = path;
            document.getElementById('modalSize').textContent = formatSize(parseInt(size));
            document.getElementById('modalLocation').textContent = location;
            document.getElementById('imageUrl').value = window.location.origin + path;
            document.getElementById('imageModal').classList.remove('hidden');
        }

        function closeModal(event) {
            if (!event || event.target === document.getElementById('imageModal')) {
                document.getElementById('imageModal').classList.add('hidden');
            }
        }

        function copyUrl() {
            const urlInput = document.getElementById('imageUrl');
            urlInput.select();
            document.execCommand('copy');
            alert('URL copied to clipboard!');
        }

        function deleteImage(filename, location) {
            if (confirm('Are you sure you want to delete this image? This cannot be undone.')) {
                fetch('/admin/media/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filepath: filename, location: location })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    }
                });
            }
        }
    </script>
</body>
</html>
