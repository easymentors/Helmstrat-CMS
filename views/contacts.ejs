<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Submissions | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
            <div class="text-gray-400 text-sm">Contact Form Submissions</div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-bold text-white">Contact Form Submissions</h1>
                <p class="text-gray-400 text-sm">View all messages sent through the contact form</p>
            </div>
            <div class="text-gray-400 text-sm">
                <%= contacts.length %> message<%= contacts.length !== 1 ? 's' : '' %>
            </div>
        </div>

        <% if (contacts.length > 0) { %>
        <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-900 text-gray-400 text-sm uppercase">
                    <tr>
                        <th class="px-6 py-4 text-left">Date</th>
                        <th class="px-6 py-4 text-left">Name</th>
                        <th class="px-6 py-4 text-left">Email</th>
                        <th class="px-6 py-4 text-left">Subject</th>
                        <th class="px-6 py-4 text-left">Message</th>
                        <th class="px-6 py-4 text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700">
                    <% contacts.reverse().forEach(function(contact) { %>
                    <tr class="hover:bg-gray-750">
                        <td class="px-6 py-4 text-gray-400 text-sm">
                            <%= new Date(contact.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                        </td>
                        <td class="px-6 py-4 text-white font-medium"><%= contact.name %></td>
                        <td class="px-6 py-4">
                            <a href="mailto:<%= contact.email %>" class="text-teal-400 hover:text-teal-300"><%= contact.email %></a>
                        </td>
                        <td class="px-6 py-4 text-gray-300"><%= contact.subject || 'No Subject' %></td>
                        <td class="px-6 py-4 text-gray-400 text-sm max-w-xs truncate" title="<%= contact.message %>">
                            <%= contact.message %>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button onclick="viewContact('<%= contact.id %>')" class="text-teal-400 hover:text-teal-300 text-sm mr-3">View</button>
                            <button onclick="deleteContact('<%= contact.id %>')" class="text-red-400 hover:text-red-300 text-sm">Delete</button>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } else { %>
        <div class="bg-gray-800 rounded-xl p-12 text-center border border-gray-700">
            <div class="w-16 h-16 bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
            </div>
            <p class="text-gray-400">No contact form submissions yet</p>
        </div>
        <% } %>
    </main>

    <!-- View Contact Modal -->
    <div id="viewModal" class="fixed inset-0 bg-black/90 z-50 hidden flex items-center justify-center p-4" onclick="closeModal(event)">
        <div class="bg-gray-900 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-hidden">
            <div class="p-4 border-b border-gray-800 flex justify-between items-center">
                <h3 class="text-white font-semibold">Contact Details</h3>
                <button onclick="closeModal()" class="text-gray-400 hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="p-6 overflow-auto max-h-[60vh]">
                <div class="mb-4">
                    <label class="text-gray-500 text-sm">Date</label>
                    <p id="modalDate" class="text-white"></p>
                </div>
                <div class="mb-4">
                    <label class="text-gray-500 text-sm">Name</label>
                    <p id="modalName" class="text-white font-medium"></p>
                </div>
                <div class="mb-4">
                    <label class="text-gray-500 text-sm">Email</label>
                    <p id="modalEmail" class="text-teal-400"></p>
                </div>
                <div class="mb-4">
                    <label class="text-gray-500 text-sm">Subject</label>
                    <p id="modalSubject" class="text-white"></p>
                </div>
                <div class="mb-4">
                    <label class="text-gray-500 text-sm">Message</label>
                    <p id="modalMessage" class="text-white whitespace-pre-wrap"></p>
                </div>
            </div>
            <div class="p-4 border-t border-gray-800 flex justify-between">
                <button onclick="closeModal()" class="bg-gray-700 text-white px-6 py-2 rounded-lg hover:bg-gray-600">Close</button>
                <button onclick="deleteCurrentContact()" class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700">Delete</button>
            </div>
        </div>
    </div>

    <script>
        let currentContactId = null;
        const contacts = <%- JSON.stringify(contacts) %>;

        function viewContact(id) {
            const contact = contacts.find(c => c.id === id);
            if (contact) {
                currentContactId = id;
                document.getElementById('modalDate').textContent = new Date(contact.createdAt).toLocaleString();
                document.getElementById('modalName').textContent = contact.name;
                document.getElementById('modalEmail').textContent = contact.email;
                document.getElementById('modalEmail').href = 'mailto:' + contact.email;
                document.getElementById('modalSubject').textContent = contact.subject || 'No Subject';
                document.getElementById('modalMessage').textContent = contact.message;
                document.getElementById('viewModal').classList.remove('hidden');
            }
        }

        function deleteCurrentContact() {
            if (currentContactId) {
                deleteContact(currentContactId);
                closeModal();
            }
        }

        function closeModal(event) {
            if (!event || event.target === document.getElementById('viewModal')) {
                document.getElementById('viewModal').classList.add('hidden');
                currentContactId = null;
            }
        }

        function deleteContact(id) {
            if (confirm('Are you sure you want to delete this contact?')) {
                fetch('/admin/contacts/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: id })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    }
                });
            }
        }
    </script>
</body>
</html>
