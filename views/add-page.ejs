<!-- add-page.ejs - Add New Page -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Page | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen">
    <!-- Header -->
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-8">Add New Page</h1>

        <form action="/admin/add-page" method="POST" enctype="multipart/form-data" class="space-y-6">
            <!-- Title -->
            <div>
                <label class="block text-gray-300 mb-2">Page Title *</label>
                <input type="text" name="title" required
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500"
                    placeholder="e.g., About Us">
            </div>

            <!-- Slug -->
            <div>
                <label class="block text-gray-300 mb-2">URL Slug *</label>
                <input type="text" name="slug" required
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500"
                    placeholder="e.g., about-us">
                <p class="text-gray-500 text-sm mt-1">This will be the URL: yoursite.com/slug</p>
            </div>

            <!-- Content -->
            <div>
                <label class="block text-gray-300 mb-2">Page Content *</label>
                <textarea name="content" rows="8" required
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500"
                    placeholder="Enter page content..."></textarea>
            </div>

            <!-- Image Upload -->
            <div>
                <label class="block text-gray-300 mb-2">Feature Image</label>
                <input type="file" name="image" accept="image/*"
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
            </div>

            <!-- Video Upload -->
            <div>
                <label class="block text-gray-300 mb-2">Video (optional)</label>
                <input type="file" name="video" accept="video/*"
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
            </div>

            <!-- Submit -->
            <div class="flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Create Page
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>
</body>
</html>
