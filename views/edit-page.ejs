<!-- edit-page.ejs - Edit Existing Page -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Page | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen">
    <!-- Header -->
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-8">Edit Page: <%= page.title %></h1>

        <form action="/admin/edit/<%= page.id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
            <!-- Title -->
            <div>
                <label class="block text-gray-300 mb-2">Page Title *</label>
                <input type="text" name="title" value="<%= page.title %>" required
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
            </div>

            <!-- Slug -->
            <div>
                <label class="block text-gray-300 mb-2">URL Slug *</label>
                <input type="text" name="slug" value="<%= page.slug.replace('/', '') %>" required
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
            </div>

            <!-- Content -->
            <div>
                <label class="block text-gray-300 mb-2">Page Content *</label>
                <textarea name="content" rows="8" required
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500"><%= page.content %></textarea>
            </div>

            <!-- Current Image -->
            <% if (page.image) { %>
            <div>
                <label class="block text-gray-300 mb-2">Current Image</label>
                <img src="<%= page.image %>" alt="Current" class="h-32 rounded-lg mb-2">
                <p class="text-gray-500 text-sm">Upload a new image to replace the current one</p>
            </div>
            <% } %>

            <!-- New Image Upload -->
            <div>
                <label class="block text-gray-300 mb-2">Upload New Image</label>
                <input type="file" name="image" accept="image/*"
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
            </div>

            <!-- Submit -->
            <div class="flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Save Changes
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>
</body>
</html>
