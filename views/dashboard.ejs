<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen">
    <!-- Header -->
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-teal-500 to-teal-400 flex items-center justify-center">
                    <span class="text-white font-bold text-xl">H</span>
                </div>
                <span class="text-white font-bold text-xl">Helmstrat CMS</span>
            </div>
            <div class="flex items-center space-x-4">
                <a href="/" target="_blank" class="text-gray-400 hover:text-white">View Website</a>
                <a href="/admin/media" class="bg-gray-700 text-white px-4 py-2 rounded-lg hover:bg-gray-600">Media</a>
                <a href="/admin/settings" class="bg-gray-700 text-white px-4 py-2 rounded-lg hover:bg-gray-600">Settings</a>
                <a href="/admin/logout" class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700">Logout</a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-2xl font-bold text-white">Pages Dashboard</h1>
            <a href="/admin/add-page" class="bg-teal-500 text-white px-6 py-2 rounded-lg hover:bg-teal-600">+ Add New Page</a>
        </div>

        <!-- All Pages Grid -->
        <div class="mb-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-semibold text-white">All Pages</h2>
                <a href="/admin/navigation" class="bg-orange-600 text-white px-4 py-2 rounded-lg hover:bg-orange-700 text-sm flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
                    </svg>
                    Navigation Order
                </a>
            </div>
            
            <% const colors = ['teal', 'blue', 'purple', 'amber', 'green', 'pink', 'red', 'indigo']; %>
            <% const icons = ['🏠', '📄', '📝', '💬', '⚙️', '📱', '🛒', '📧', '📋', 'ℹ️', '🎯', '🌟']; %>
            
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4">
                <% pages.forEach(function(page, index) { %>
                <% 
                    const colorIndex = index % colors.length;
                    const iconIndex = index % icons.length;
                    let editUrl = '/admin/edit/' + page.id;
                    let pageIcon = icons[iconIndex];
                    
                    // Map specific pages to their edit routes
                    if (page.slug === '/') editUrl = '/admin/edit-home';
                    else if (page.slug === '/about') editUrl = '/admin/edit-about';
                    else if (page.slug === '/services') editUrl = '/admin/edit-services';
                    else if (page.slug === '/testimonials') editUrl = '/admin/edit-testimonials';
                    else if (page.slug === '/contact') editUrl = '/admin/edit-contact';
                    else if (page.slug === '/products') editUrl = '/admin/edit-products';
                    else if (page.slug === '/blog') editUrl = '/admin/edit-blog';
                    
                    // Map icons to specific pages
                    if (page.slug === '/') pageIcon = '🏠';
                    else if (page.slug === '/about') pageIcon = 'ℹ️';
                    else if (page.slug === '/services') pageIcon = '⚙️';
                    else if (page.slug === '/testimonials') pageIcon = '💬';
                    else if (page.slug === '/contact') pageIcon = '📧';
                    else if (page.slug === '/products') pageIcon = '📱';
                    else if (page.slug === '/blog') pageIcon = '📰';
                %>
                <a href="<%= editUrl %>" class="bg-gray-800 rounded-xl p-4 border border-gray-700 hover:border-teal-500 hover:scale-105 transition-all text-center group">
                    <div class="w-14 h-14 bg-<%= colors[colorIndex] %>-500/20 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-<%= colors[colorIndex] %>-500/30 transition-colors">
                        <span class="text-3xl"><%= pageIcon %></span>
                    </div>
                    <div class="text-white font-medium mb-1 truncate"><%= page.title %></div>
                    <div class="text-gray-500 text-xs truncate"><%= page.slug %></div>
                </a>
                <% }); %>
            </div>
            
            <% if (pages.length === 0) { %>
            <div class="bg-gray-800 rounded-xl p-12 text-center border border-gray-700">
                <p class="text-gray-400 mb-4">No pages yet. Create your first page to get started.</p>
                <a href="/admin/add-page" class="bg-teal-500 text-white px-6 py-2 rounded-lg hover:bg-teal-600">+ Add New Page</a>
            </div>
            <% } %>
        </div>
    </main>
</body>
</html>
