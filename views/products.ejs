<%- include('header') %>

<!-- Products Section -->
<section id="products" class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-primary font-semibold text-sm tracking-wider uppercase"><%= page.subtitle %></span>
            <h1 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
                Our Products
            </h1>
            <p class="text-gray-400 max-w-2xl mx-auto">
                <%= page.content %>
            </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
            <% const products = page.products || []; %>
            <% if (products.length === 0) { %>
            <div class="gradient-border rounded-2xl p-8 text-center">
                <p class="text-gray-400">No products yet. Check back soon!</p>
            </div>
            <% } %>
            <% products.forEach(function(product, index) { %>
            <div class="gradient-border rounded-2xl overflow-hidden" data-aos="fade-up" data-aos-delay="<%= (index + 1) * 100 %>">
                <div class="bg-dark-700 p-8">
                    <div class="flex flex-col md:flex-row gap-8">
                        <div class="w-full md:w-1/3">
                            <% if(product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full rounded-xl">
                            <% } else { %>
                            <div class="w-full aspect-square bg-dark-600 rounded-xl flex items-center justify-center">
                                <i data-lucide="package" class="w-20 h-20 text-gray-600"></i>
                            </div>
                            <% } %>
                        </div>
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-2">
                                <h3 class="text-2xl font-bold text-white"><%= product.name %></h3>
                                <% if(product.platform) { %>
                                <span class="px-3 py-1 bg-primary/20 text-primary text-xs font-medium rounded-full"><%= product.platform %></span>
                                <% } %>
                            </div>
                            <% if(product.tagline) { %>
                            <p class="text-primary text-sm mb-4"><%= product.tagline %></p>
                            <% } %>
                            <% if(product.description) { %>
                            <p class="text-gray-400 text-sm mb-6 leading-relaxed">
                                <%= product.description %>
                            </p>
                            <% } %>
                            <% if(product.features && product.features.length > 0) { %>
                            <div class="flex flex-wrap gap-2 mb-6">
                                <% product.features.forEach(function(feature) { %>
                                <span class="px-3 py-1 bg-dark-600 text-gray-300 text-xs rounded-full">
                                    <i data-lucide="check" class="w-3 h-3 inline mr-1 text-primary"></i>
                                    <%= feature %>
                                </span>
                                <% }); %>
                            </div>
                            <% } %>
                            <% if(product.playStoreUrl) { %>
                            <a href="<%= product.playStoreUrl %>" target="_blank" 
                                class="inline-flex items-center px-6 py-3 bg-dark-600 border border-white/10 text-white font-medium rounded-xl hover:bg-dark-500 transition-colors">
                                <i data-lucide="play" class="w-5 h-5 mr-2"></i>
                                View on Play Store
                            </a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<%- include('footer') %>
