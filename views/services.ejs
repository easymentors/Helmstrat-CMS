<%- include('header') %>

<!-- Services Section -->
<section id="services" class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-primary font-semibold text-sm tracking-wider uppercase"><%= page.subtitle %></span>
            <h1 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
                Our Services
            </h1>
            <p class="text-gray-400 max-w-2xl mx-auto">
                <%= page.content %>
            </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% page.services.forEach(function(service, index) { %>
            <div class="group gradient-border rounded-2xl p-8 hover:glow transition-all duration-300" data-aos="fade-up" data-aos-delay="<%= (index + 1) * 100 %>">
                <div class="w-14 h-14 bg-gradient-to-br from-<%= service.color %>/20 to-<%= service.color %>/20 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <i data-lucide="<%= service.icon %>" class="w-7 h-7 text-<%= service.color %>"></i>
                </div>
                <h3 class="text-xl font-semibold text-white mb-3"><%= service.title %></h3>
                <p class="text-gray-400 text-sm leading-relaxed">
                    <%= service.description %>
                </p>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<%- include('footer') %>
