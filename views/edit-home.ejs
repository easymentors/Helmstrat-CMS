<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Home Page | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-8">Edit Home Page</h1>

        <form action="/admin/edit-home" method="POST" class="space-y-8">
            <!-- Hero Section -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">Hero Section</h2>
                
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-gray-300 mb-2">Hero Title</label>
                        <input type="text" name="heroTitle" value="<%= page.heroTitle || 'We Build' %>" required
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Hero Gradient Text</label>
                        <input type="text" name="heroGradientText" value="<%= page.heroGradientText || 'Digital Excellence' %>" required
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                </div>

                <div class="mt-4">
                    <label class="block text-gray-300 mb-2">Subtitle Badge</label>
                    <input type="text" name="subtitle" value="<%= page.subtitle || 'Software Agency' %>" required
                        class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                </div>

                <div class="mt-4">
                    <label class="block text-gray-300 mb-2">Content</label>
                    <textarea name="content" rows="3" required
                        class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500"><%= page.content || '' %></textarea>
                </div>

                <div class="grid md:grid-cols-2 gap-6 mt-4">
                    <div>
                        <label class="block text-gray-300 mb-2">Primary CTA Button</label>
                        <input type="text" name="ctaPrimary" value="<%= page.ctaPrimary || 'Start Your Project' %>" required
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Secondary CTA Button</label>
                        <input type="text" name="ctaSecondary" value="<%= page.ctaSecondary || 'Our Services' %>" required
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">Statistics</h2>
                
                <% const stats = page.stats || [
                    { value: '50+', label: 'Projects Delivered' },
                    { value: '30+', label: 'Happy Clients' },
                    { value: '5+', label: 'Years Experience' }
                ]; %>
                
                <% stats.forEach(function(stat, index) { %>
                <div class="grid md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-gray-400 text-sm mb-1">Value <%= index + 1 %></label>
                        <input type="text" name="statValue<%= index %>" value="<%= stat.value %>"
                            class="w-full px-4 py-2 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-400 text-sm mb-1">Label <%= index + 1 %></label>
                        <input type="text" name="statLabel<%= index %>" value="<%= stat.label %>"
                            class="w-full px-4 py-2 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                </div>
                <% }); %>
            </div>

            <div class="flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Save Changes
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>
</body>
</html>
