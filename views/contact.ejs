<%- include('header') %>

<!-- Contact Section -->
<section id="contact" class="pt-32 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16">
            <div data-aos="fade-right" data-aos-duration="800">
                <span class="text-primary font-semibold text-sm tracking-wider uppercase"><%= page.subtitle %></span>
                <h1 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-6">
                    Let's Build Something<br>Amazing Together
                </h1>
                <p class="text-gray-400 mb-8 leading-relaxed">
                    <%= page.content %>
                </p>

                <div class="space-y-6">
                    <% if(siteSettings?.email) { %>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="mail" class="w-5 h-5 text-primary"></i>
                        </div>
                        <div>
                            <div class="text-white font-medium">Email</div>
                            <div class="text-gray-400"><%= siteSettings.email %></div>
                        </div>
                    </div>
                    <% } %>
                    <% if(siteSettings?.phone) { %>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="phone" class="w-5 h-5 text-primary"></i>
                        </div>
                        <div>
                            <div class="text-white font-medium">Phone</div>
                            <div class="text-gray-400"><%= siteSettings.phone %></div>
                        </div>
                    </div>
                    <% } %>
                    <% if(siteSettings?.address) { %>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="map-pin" class="w-5 h-5 text-primary"></i>
                        </div>
                        <div>
                            <div class="text-white font-medium">Location</div>
                            <div class="text-gray-400"><%= siteSettings.address %></div>
                        </div>
                    </div>
                    <% } %>
                </div>

                <% const social = siteSettings?.socialLinks || {}; %>
                <% if(social.twitter || social.linkedin || social.github || social.instagram) { %>
                <div class="flex items-center space-x-4 mt-8">
                    <% if(social.twitter && social.twitter !== '#') { %>
                    <a href="<%= social.twitter %>" class="w-10 h-10 bg-dark-700 rounded-lg flex items-center justify-center hover:bg-primary/20 transition-colors">
                        <i data-lucide="twitter" class="w-5 h-5"></i>
                    </a>
                    <% } %>
                    <% if(social.linkedin && social.linkedin !== '#') { %>
                    <a href="<%= social.linkedin %>" class="w-10 h-10 bg-dark-700 rounded-lg flex items-center justify-center hover:bg-primary/20 transition-colors">
                        <i data-lucide="linkedin" class="w-5 h-5"></i>
                    </a>
                    <% } %>
                    <% if(social.github && social.github !== '#') { %>
                    <a href="<%= social.github %>" class="w-10 h-10 bg-dark-700 rounded-lg flex items-center justify-center hover:bg-primary/20 transition-colors">
                        <i data-lucide="github" class="w-5 h-5"></i>
                    </a>
                    <% } %>
                    <% if(social.instagram && social.instagram !== '#') { %>
                    <a href="<%= social.instagram %>" class="w-10 h-10 bg-dark-700 rounded-lg flex items-center justify-center hover:bg-primary/20 transition-colors">
                        <i data-lucide="instagram" class="w-5 h-5"></i>
                    </a>
                    <% } %>
                </div>
                <% } %>
            </div>

            <div data-aos="fade-left" data-aos-duration="800" data-aos-delay="200">
                <form class="gradient-border rounded-2xl p-8 relative z-10" id="contact-form">
                    <div class="space-y-6">
                        <div>
                            <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Your Name</label>
                            <input type="text" id="name" name="name" required
                                class="form-input w-full px-4 py-3 bg-dark-700 border border-white/10 rounded-xl placeholder-gray-500 transition-colors"
                                placeholder="John Doe">
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Email Address</label>
                            <input type="email" id="email" name="email" required
                                class="form-input w-full px-4 py-3 bg-dark-700 border border-white/10 rounded-xl placeholder-gray-500 transition-colors"
                                placeholder="john@example.com">
                        </div>
                        <div>
                            <label for="subject" class="block text-sm font-medium text-gray-300 mb-2">Subject</label>
                            <input type="text" id="subject" name="subject"
                                class="form-input w-full px-4 py-3 bg-dark-700 border border-white/10 rounded-xl placeholder-gray-500 transition-colors"
                                placeholder="Project Inquiry">
                        </div>
                        <div>
                            <label for="message" class="block text-sm font-medium text-gray-300 mb-2">Message</label>
                            <textarea id="message" name="message" rows="5" required
                                class="form-input w-full px-4 py-3 bg-dark-700 border border-white/10 rounded-xl placeholder-gray-500 transition-colors resize-none"
                                placeholder="Tell us about your project..."></textarea>
                        </div>
                        <button type="submit" id="submit-btn"
                            class="w-full px-8 py-4 bg-gradient-to-r from-primary to-primary-light text-white font-semibold rounded-xl hover:shadow-lg hover:shadow-primary/25 transition-all flex items-center justify-center cursor-pointer">
                            <span>Send Message</span>
                            <i data-lucide="send" class="w-5 h-5 ml-2"></i>
                        </button>
                    </div>
                </form>
                <div id="success-message" class="hidden gradient-border rounded-2xl p-8 text-center">
                    <div class="w-16 h-16 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i data-lucide="check-circle" class="w-8 h-8 text-green-400"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-white mb-2">Message Sent!</h3>
                    <p class="text-gray-400">Thank you for reaching out. We'll get back to you soon.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const contactForm = document.getElementById('contact-form');
    const successMessage = document.getElementById('success-message');
    const submitBtn = document.getElementById('submit-btn');

    contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        submitBtn.innerHTML = '<span class="animate-pulse">Sending...</span>';
        submitBtn.disabled = true;

        const formData = new FormData(contactForm);

        try {
            const response = await fetch('/api/contact', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(Object.fromEntries(formData))
            });

            const result = await response.json();

            if (result.success) {
                contactForm.classList.add('hidden');
                successMessage.classList.remove('hidden');
                successMessage.classList.add('animate-fade-in');
            } else {
                alert(result.message);
                submitBtn.innerHTML = '<span>Send Message</span><i data-lucide="send" class="w-5 h-5 ml-2"></i>';
                submitBtn.disabled = false;
                lucide.createIcons();
            }
        } catch (error) {
            alert('An error occurred. Please try again later.');
            submitBtn.innerHTML = '<span>Send Message</span><i data-lucide="send" class="w-5 h-5 ml-2"></i>';
            submitBtn.disabled = false;
            lucide.createIcons();
        }
    });
</script>

<%- include('footer') %>
