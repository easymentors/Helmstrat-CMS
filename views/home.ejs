<!-- Products Preview Section -->
<% const homeProducts = (function() {
    const prods = page.products;
    if (prods && prods.length > 0) return prods;
    return [{ name: 'Desi Recipes', tagline: 'Authentic Pakistani & Indian Recipes', description: 'Discover the rich flavors of Pakistani and Indian cuisine with our comprehensive recipe app.', image: '/images/App.png', platform: 'Android', playStoreUrl: 'https://play.google.com/store/apps/details?id=com.smartrasoi.app' }];
})(); %>
<% if(homeProducts && homeProducts.length > 0) { %>
<section id="products-preview" class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-primary font-semibold text-sm tracking-wider uppercase">Our Products</span>
            <h2 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
                <%= homeProducts.length === 1 ? 'Featured Product' : 'Featured Products' %>
            </h2>
            <p class="text-gray-400 max-w-2xl mx-auto">
                Explore our suite of innovative digital products designed to simplify your life and boost your productivity.
            </p>
        </div>

        <% homeProducts.slice(0, 2).forEach(function(product, index) { %>
        <div class="gradient-border rounded-2xl overflow-hidden max-w-4xl mx-auto mb-6 <%= index > 0 ? 'hidden md:block' : '' %>" data-aos="fade-up">
            <div class="bg-dark-700 p-8">
                <div class="flex flex-col md:flex-row gap-8 items-center">
                    <div class="w-full md:w-1/3">
                        <img src="<%= product.image || '/images/App.png' %>" alt="<%= product.name %>" class="w-full rounded-xl">
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <h3 class="text-2xl font-bold text-white"><%= product.name %></h3>
                            <span class="px-3 py-1 bg-primary/20 text-primary text-xs font-medium rounded-full"><%= product.platform || 'Android' %></span>
                        </div>
                        <% if(product.tagline) { %>
                        <p class="text-primary text-sm mb-4"><%= product.tagline %></p>
                        <% } %>
                        <p class="text-gray-400 text-sm mb-6 leading-relaxed">
                            <%= product.description %>
                        </p>
                        <a href="/products" class="inline-flex items-center px-6 py-3 bg-dark-600 border border-white/10 text-white font-medium rounded-xl hover:bg-dark-500 transition-colors">
                            View All Products
                            <i data-lucide="arrow-right" class="w-5 h-5 ml-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
</section>
<% } %>

<!-- Contact CTA Section -->
<section id="contact" class="py-24 bg-dark-800/50">
