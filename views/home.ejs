<%- include('header') %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div class="text-center lg:text-left" data-aos="fade-up" data-aos-duration="800">
                <div class="inline-flex items-center px-4 py-2 bg-dark-700 rounded-full border border-white/10 mb-6">
                    <span class="w-2 h-2 bg-primary rounded-full mr-2 animate-pulse"></span>
                    <span class="text-sm text-gray-400"><%= page.subtitle %></span>
                </div>
                
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
                    <%= page.heroTitle %><br>
                    <span class="gradient-text"><%= page.heroGradientText %></span>
                </h1>
                
                <p class="text-lg text-gray-400 mb-8 max-w-xl mx-auto lg:mx-0">
                    <%= page.content %>
                </p>
                
                <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                    <a href="/contact" class="px-8 py-4 bg-gradient-to-r from-primary to-primary-light text-white font-semibold rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all text-center">
                        <%= page.ctaPrimary %>
                    </a>
                    <a href="/services" class="px-8 py-4 border border-white/20 text-white font-semibold rounded-full hover:bg-white/5 transition-all text-center">
                        <%= page.ctaSecondary %>
                    </a>
                </div>

                <div class="flex items-center justify-center lg:justify-start gap-8 mt-12 pt-8 border-t border-white/10">
                    <% page.stats.forEach(function(stat, index) { %>
                    <% if(index > 0) { %>
                    <div class="w-px h-12 bg-white/10"></div>
                    <% } %>
                    <div>
                        <div class="text-3xl font-bold text-white"><%= stat.value %></div>
                        <div class="text-sm text-gray-500"><%= stat.label %></div>
                    </div>
                    <% }); %>
                </div>
            </div>

            <div class="relative hidden lg:block" data-aos="fade-left" data-aos-duration="1000" data-aos-delay="200">
                <div class="relative">
                    <div class="gradient-border rounded-2xl overflow-hidden glow">
                        <div class="bg-dark-700 px-4 py-3 flex items-center space-x-2 border-b border-white/5">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                            <span class="ml-4 text-xs text-gray-500">app.js</span>
                        </div>
                        <div class="p-6 font-mono text-sm">
                            <div class="text-gray-500">// Your vision, our code</div>
                            <div class="mt-2"><span class="text-purple-400">const</span> <span class="text-blue-400">helmstrat</span> = {</div>
                            <div class="ml-4"><span class="text-green-400">excellence</span>: <span class="text-amber-300">true</span>,</div>
                            <div class="ml-4"><span class="text-green-400">innovation</span>: <span class="text-amber-300">true</span>,</div>
                            <div class="ml-4"><span class="text-green-400">dedication</span>: <span class="text-amber-300">true</span></div>
                            <div>};</div>
                        </div>
                    </div>

                    <div class="absolute -top-4 -right-4 bg-dark-700 rounded-xl p-4 border border-white/10 animate-bounce" style="animation-duration: 3s;">
                        <i data-lucide="zap" class="w-6 h-6 text-primary"></i>
                    </div>
                    <div class="absolute -bottom-4 -left-4 bg-dark-700 rounded-xl p-4 border border-white/10 animate-bounce" style="animation-duration: 4s; animation-delay: 1s;">
                        <i data-lucide="shield-check" class="w-6 h-6 text-green-400"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="py-24 bg-dark-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div data-aos="fade-right" data-aos-duration="800">
                <div class="relative">
                    <div class="gradient-border rounded-2xl p-1">
                        <div class="bg-dark-700 rounded-xl p-8">
                            <div class="grid grid-cols-2 gap-4">
                                <div class="bg-dark-600 rounded-xl p-6 text-center">
                                    <i data-lucide="code-2" class="w-10 h-10 mx-auto text-primary mb-3"></i>
                                    <div class="text-white font-semibold">Clean Code</div>
                                </div>
                                <div class="bg-dark-600 rounded-xl p-6 text-center">
                                    <i data-lucide="users" class="w-10 h-10 mx-auto text-primary mb-3"></i>
                                    <div class="text-white font-semibold">Team Collaboration</div>
                                </div>
                                <div class="bg-dark-600 rounded-xl p-6 text-center">
                                    <i data-lucide="rocket" class="w-10 h-10 mx-auto text-primary mb-3"></i>
                                    <div class="text-white font-semibold">Fast Delivery</div>
                                </div>
                                <div class="bg-dark-600 rounded-xl p-6 text-center">
                                    <i data-lucide="headphones" class="w-10 h-10 mx-auto text-primary mb-3"></i>
                                    <div class="text-white font-semibold">24/7 Support</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div data-aos="fade-left" data-aos-duration="800" data-aos-delay="200">
                <span class="text-primary font-semibold text-sm tracking-wider uppercase">About Us</span>
                <h2 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-6">
                    Your Partner in<br>Digital Transformation
                </h2>
                <p class="text-gray-400 mb-6 leading-relaxed">
                    At Helmstrat, we believe in building more than just software – we build partnerships. Our team of passionate developers, designers, and strategists work together to deliver solutions that make an impact.
                </p>
                <p class="text-gray-400 mb-8 leading-relaxed">
                    From startups to enterprises, we adapt to your needs and deliver results that exceed expectations. Our commitment to quality, transparency, and innovation sets us apart.
                </p>
                
                <div class="space-y-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center">
                            <i data-lucide="check" class="w-4 h-4 text-primary"></i>
                        </div>
                        <span class="text-gray-300">Agile development methodology</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center">
                            <i data-lucide="check" class="w-4 h-4 text-primary"></i>
                        </div>
                        <span class="text-gray-300">Transparent communication</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center">
                            <i data-lucide="check" class="w-4 h-4 text-primary"></i>
                        </div>
                        <span class="text-gray-300">Post-launch support & maintenance</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

