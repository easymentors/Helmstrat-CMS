<!-- upload-template.ejs - Upload New Template -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Template | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen">
    <!-- Header -->
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-8">Upload New Template</h1>

        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 mb-8">
            <h2 class="text-lg font-semibold text-white mb-4">Template Folder Location</h2>
            <p class="text-gray-400 mb-2">Templates will be saved to:</p>
            <code class="bg-gray-800 text-teal-400 px-4 py-2 rounded block">C:\Users\Ammi\CMS Templates</code>
        </div>

        <form action="/admin/upload-template" method="POST" enctype="multipart/form-data" class="space-y-6">
            <!-- Template Upload -->
            <div>
                <label class="block text-gray-300 mb-2">Select Template File</label>
                <input type="file" name="template" accept=".html,.ejs,.htm"
                    class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                <p class="text-gray-500 text-sm mt-1">Supported formats: .html, .ejs, .htm</p>
            </div>

            <!-- Submit -->
            <div class="flex space-x-4">
                <button type="submit" class="bg-purple-600 text-white px-8 py-3 rounded-lg hover:bg-purple-700 font-semibold">
                    Upload Template
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>
</body>
</html>
