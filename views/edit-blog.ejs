<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Blog | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></link>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
        .sortable-ghost { opacity: 0.4; }
        .sortable-chosen { background-color: #1f2937 !important; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
            <button type="button" onclick="addPost()" class="bg-teal-600 text-white px-4 py-2 rounded-lg hover:bg-teal-700 text-sm">
                + Add New Post
            </button>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-8">Blog Posts</h1>

        <form action="/admin/blog" method="POST" enctype="multipart/form-data" id="blogForm">
            <input type="hidden" name="postsData" id="postsData">

            <div id="postsContainer" class="space-y-6">
                <!-- Posts will be added here by JavaScript -->
            </div>

            <div class="mt-8 flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Save All Posts
                </button>
                <a href="/blog" target="_blank" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Preview Blog
                </a>
            </div>
        </form>
    </main>

    <script>
        let posts = <%- JSON.stringify(posts) %>;
        const container = document.getElementById('postsContainer');
        const postsDataInput = document.getElementById('postsData');

        function renderPosts() {
            container.innerHTML = '';
            posts.forEach((post, index) => {
                const html = createPostHTML(post, index);
                container.insertAdjacentHTML('beforeend', html);
            });
            updatePostsData();
        }

        function createPostHTML(post, index) {
            const date = post.date ? new Date(post.date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0];
            return `
                <div class="post-card bg-gray-800 rounded-xl border border-gray-700 p-6" data-index="${index}">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="text-white font-semibold">Post ${index + 1}</h3>
                        <button type="button" onclick="removePost(${index})" class="text-red-400 hover:text-red-300 text-sm">
                            Remove
                        </button>
                    </div>
                    <div class="grid md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Title *</label>
                            <input type="text" name="title_${index}" value="${escapeHtml(post.title || '')}" required
                                class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500"
                                placeholder="Blog Post Title">
                        </div>
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Author *</label>
                            <input type="text" name="author_${index}" value="${escapeHtml(post.author || '')}" required
                                class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500"
                                placeholder="Author Name">
                        </div>
                    </div>
                    <div class="grid md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Date</label>
                            <input type="date" name="date_${index}" value="${date}"
                                class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Post Image</label>
                            ${post.image ? `<div class="mb-2"><img src="${post.image}" alt="Current" class="h-16 rounded border border-gray-600"></div>` : ''}
                            <div class="space-y-2">
                                <input type="url" name="imageUrl_${index}" value="${escapeHtml(post.image || '')}"
                                    class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500"
                                    placeholder="Or enter image URL">
                                <div class="text-gray-500 text-xs text-center">— OR —</div>
                                <input type="file" name="blogImage_${index}" accept="image/*"
                                    class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500"
                                    placeholder="Upload image file">
                            </div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="block text-gray-400 text-sm mb-1">Content *</label>
                        <textarea name="content_${index}" rows="6" required
                            class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500"
                            placeholder="Write your blog post content here...">${escapeHtml(post.content || '')}</textarea>
                        <div class="mt-2 bg-gray-700/50 rounded-lg p-3 text-xs text-gray-400">
                            <p class="font-medium text-gray-300 mb-2">Formatting Guide:</p>
                            <div class="grid grid-cols-2 gap-1">
                                <span><code class="bg-gray-800 px-1 rounded">**bold**</code> → <strong>bold</strong></span>
                                <span><code class="bg-gray-800 px-1 rounded">*italic*</code> → <em>italic</em></span>
                                <span><code class="bg-gray-800 px-1 rounded">__underline__</code> → <u>underline</u></span>
                                <span><code class="bg-gray-800 px-1 rounded">~~strike~~</code> → <del>strike</del></span>
                                <span><code class="bg-gray-800 px-1 rounded"># Heading 1</code> → Large Heading</span>
                                <span><code class="bg-gray-800 px-1 rounded">## Heading 2</code> → Small Heading</span>
                                <span><code class="bg-gray-800 px-1 rounded">- bullet point</code> → • bullet</span>
                                <span><code class="bg-gray-800 px-1 rounded">1. numbered</code> → 1. numbered</span>
                            </div>
                            <p class="mt-2 text-gray-500">Use blank lines to separate paragraphs</p>
                        </div>
                    </div>
                </div>
            `;
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function addPost() {
            posts.push({
                title: '',
                author: 'Admin',
                date: new Date().toISOString(),
                image: '',
                content: ''
            });
            renderPosts();
        }

        function removePost(index) {
            if (posts.length <= 1) {
                alert('You must have at least one blog post.');
                return;
            }
            posts.splice(index, 1);
            renderPosts();
        }

        function updatePostsData() {
            const cardData = [];
            container.querySelectorAll('.post-card').forEach((card, index) => {
                const title = card.querySelector(`[name="title_${index}"]`)?.value || '';
                const author = card.querySelector(`[name="author_${index}"]`)?.value || '';
                const date = card.querySelector(`[name="date_${index}"]`)?.value || '';
                const image = card.querySelector(`[name="image_${index}"]`)?.value || '';
                const content = card.querySelector(`[name="content_${index}"]`)?.value || '';
                
                cardData.push({ title, author, date, image, content });
            });
            postsDataInput.value = JSON.stringify(cardData);
        }

        document.getElementById('blogForm').addEventListener('submit', function() {
            updatePostsData();
        });

        container.addEventListener('input', updatePostsData);

        renderPosts();
    </script>
</body>
</html>
