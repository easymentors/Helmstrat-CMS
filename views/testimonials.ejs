<%- include('header') %>

<!-- Testimonials Section -->
<section id="testimonials" class="pt-32 pb-24 bg-dark-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-primary font-semibold text-sm tracking-wider uppercase"><%= page.subtitle %></span>
            <h1 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
                What Our Clients Say
            </h1>
            <p class="text-gray-400 max-w-2xl mx-auto">
                <%= page.content %>
            </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <% page.testimonials.forEach(function(testimonial, index) { %>
            <div class="gradient-border rounded-2xl p-8" data-aos="fade-up" data-aos-delay="<%= (index + 1) * 100 %>">
                <div class="flex items-center mb-4">
                    <% for(var i = 0; i < testimonial.rating; i++) { %>
                    <i data-lucide="star" class="w-5 h-5 text-amber-400 fill-amber-400"></i>
                    <% } %>
                </div>
                <p class="text-gray-300 mb-6 leading-relaxed">
                    "<%= testimonial.text %>"
                </p>
                <div class="flex items-center">
                    <div class="w-12 h-12 rounded-full bg-gradient-to-br from-<%= testimonial.gradientFrom %> to-<%= testimonial.gradientTo %> flex items-center justify-center text-white font-semibold">
                        <%= testimonial.initials %>
                    </div>
                    <div class="ml-4">
                        <div class="text-white font-semibold"><%= testimonial.name %></div>
                        <div class="text-gray-500 text-sm"><%= testimonial.role %></div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>

        <!-- Logos -->
        <div class="mt-20 pt-12 border-t border-white/10" data-aos="fade-up">
            <p class="text-center text-gray-500 text-sm mb-8">Trusted by innovative companies</p>
            <div class="flex flex-wrap justify-center items-center gap-12 opacity-50">
                <% page.logos.forEach(function(logo) { %>
                <div class="text-2xl font-bold text-gray-400"><%= logo %></div>
                <% }); %>
            </div>
        </div>
    </div>
</section>

<%- include('footer') %>
