<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navigation Settings | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></link>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
        .sortable-ghost { opacity: 0.4; }
        .sortable-chosen { background-color: #1f2937 !important; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-2">Navigation Settings</h1>
        <p class="text-gray-400 mb-8">Drag and drop to reorder. Uncheck pages to hide them from the navigation bar.</p>

        <form action="/admin/navigation" method="POST" id="navForm">
            <input type="hidden" name="excluded" id="excludedPages" value="<%= (navOrder.excluded || []).join(',') %>">

            <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 mb-6">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-white">Page Order</h2>
                    <button type="button" onclick="toggleAll()" class="text-sm text-teal-400 hover:text-teal-300">Show All</button>
                </div>
                
                <div id="sortableList" class="space-y-2">
                    <% const sortedPages = [...pages].sort((a, b) => (a.order || 99) - (b.order || 99)); %>
                    <% const excludedPages = navOrder.excluded || []; %>
                    
                    <% sortedPages.forEach(function(page, index) { %>
                    <div class="nav-item bg-gray-800 rounded-lg p-4 flex items-center gap-4 cursor-move" data-id="<%= page.id %>">
                        <div class="text-gray-500 cursor-move">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"></path>
                            </svg>
                        </div>
                        <input type="checkbox" name="page_<%= page.id %>" id="page_<%= page.id %>" 
                            class="w-5 h-5 rounded bg-gray-700 border-gray-600 text-teal-500 focus:ring-teal-500"
                            <%= excludedPages.includes(page.id) ? '' : 'checked' %>
                            onchange="updateExcluded()">
                        <label for="page_<%= page.id %>" class="flex-1 cursor-pointer <%= excludedPages.includes(page.id) ? 'opacity-50' : '' %>">
                            <div class="text-white font-medium"><%= page.title %></div>
                            <div class="text-gray-500 text-sm"><%= page.slug %></div>
                        </label>
                        <div class="text-gray-600 text-sm order-num"><%= index + 1 %></div>
                    </div>
                    <% }); %>
                </div>
            </div>

            <div class="flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Save Navigation Order
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>

    <script>
        const sortableList = document.getElementById('sortableList');
        const excludedInput = document.getElementById('excludedPages');

        new Sortable(sortableList, {
            animation: 150,
            ghostClass: 'sortable-ghost',
            chosenClass: 'sortable-chosen',
            handle: '.cursor-move',
            onEnd: function(evt) {
                updateNumbers();
            }
        });

        function updateExcluded() {
            const excluded = [];
            const items = sortableList.querySelectorAll('.nav-item');
            
            items.forEach(item => {
                const checkbox = item.querySelector('input[type="checkbox"]');
                const label = item.querySelector('label');
                if (!checkbox.checked) {
                    excluded.push(item.dataset.id);
                    label.classList.add('opacity-50');
                } else {
                    label.classList.remove('opacity-50');
                }
            });
            
            excludedInput.value = excluded.join(',');
        }

        function updateNumbers() {
            const items = sortableList.querySelectorAll('.nav-item');
            items.forEach((item, index) => {
                const numSpan = item.querySelector('.order-num');
                const checkbox = item.querySelector('input[type="checkbox"]');
                numSpan.textContent = checkbox.checked ? index + 1 : '-';
            });
        }

        function toggleAll() {
            const checkboxes = sortableList.querySelectorAll('input[type="checkbox"]');
            checkboxes.forEach(cb => cb.checked = true);
            updateExcluded();
            updateNumbers();
        }

        document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', () => {
                updateExcluded();
                updateNumbers();
            });
        });

        updateExcluded();
        updateNumbers();
    </script>
</body>
</html>
