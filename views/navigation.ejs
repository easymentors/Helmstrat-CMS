<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navigation Settings | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
        .sortable-ghost { opacity: 0.4; }
        .sortable-chosen { background-color: #1f2937 !important; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-2">Navigation Settings</h1>
        <p class="text-gray-400 mb-8">Drag and drop to reorder pages. Only checked pages will appear in the navigation menu.</p>

        <form action="/admin/navigation" method="POST" id="navForm">
            <input type="hidden" name="pageIds" id="pageIds" value="<%= navOrder.join(',') %>">

            <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 mb-6">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-white">Page Order</h2>
                    <button type="button" onclick="selectAll()" class="text-sm text-teal-400 hover:text-teal-300">Select All</button>
                </div>
                
                <div id="sortableList" class="space-y-2">
                    <% const orderedPages = [...pages].sort((a, b) => {
                        const aIndex = navOrder.indexOf(a.id);
                        const bIndex = navOrder.indexOf(b.id);
                        if (aIndex === -1 && bIndex === -1) return 0;
                        if (aIndex === -1) return 1;
                        if (bIndex === -1) return -1;
                        return aIndex - bIndex;
                    }); %>
                    
                    <% orderedPages.forEach(function(page, index) { %>
                    <div class="nav-item bg-gray-800 rounded-lg p-4 flex items-center gap-4 cursor-move" data-id="<%= page.id %>">
                        <div class="text-gray-500 cursor-move">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"></path>
                            </svg>
                        </div>
                        <input type="checkbox" name="page_<%= page.id %>" id="page_<%= page.id %>" 
                            class="w-5 h-5 rounded bg-gray-700 border-gray-600 text-teal-500 focus:ring-teal-500"
                            <%= navOrder.includes(page.id) ? 'checked' : '' %>
                            onchange="updatePageIds()">
                        <label for="page_<%= page.id %>" class="flex-1 cursor-pointer">
                            <div class="text-white font-medium"><%= page.title %></div>
                            <div class="text-gray-500 text-sm"><%= page.slug %></div>
                        </label>
                        <div class="text-gray-600 text-sm">
                            <span class="nav-number"><%= navOrder.indexOf(page.id) !== -1 ? navOrder.indexOf(page.id) + 1 : '-' %></span>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>

            <div class="flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Save Navigation Order
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>

    <script>
        const sortableList = document.getElementById('sortableList');
        const pageIdsInput = document.getElementById('pageIds');

        new Sortable(sortableList, {
            animation: 150,
            ghostClass: 'sortable-ghost',
            chosenClass: 'sortable-chosen',
            handle: '.cursor-move',
            onEnd: function(evt) {
                updatePageIds();
                updateNumbers();
            }
        });

        function updatePageIds() {
            const checkedItems = [];
            const allItems = sortableList.querySelectorAll('.nav-item');
            
            allItems.forEach(item => {
                const checkbox = item.querySelector('input[type="checkbox"]');
                if (checkbox.checked) {
                    checkedItems.push(item.dataset.id);
                }
            });
            
            pageIdsInput.value = checkedItems.join(',');
        }

        function updateNumbers() {
            const items = sortableList.querySelectorAll('.nav-item');
            const checkedIds = [];
            
            items.forEach(item => {
                const checkbox = item.querySelector('input[type="checkbox"]');
                if (checkbox.checked) {
                    checkedIds.push(item.dataset.id);
                }
            });
            
            items.forEach((item, index) => {
                const numberSpan = item.querySelector('.nav-number');
                const id = item.dataset.id;
                const position = checkedIds.indexOf(id);
                numberSpan.textContent = position !== -1 ? position + 1 : '-';
            });
        }

        function selectAll() {
            const checkboxes = sortableList.querySelectorAll('input[type="checkbox"]');
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            
            checkboxes.forEach(cb => {
                cb.checked = !allChecked;
            });
            
            updatePageIds();
            updateNumbers();
        }

        document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', () => {
                updatePageIds();
                updateNumbers();
            });
        });

        updatePageIds();
        updateNumbers();
    </script>
</body>
</html>
