<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Testimonials Page | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-8">Edit Testimonials Page</h1>

        <form action="/admin/edit-testimonials" method="POST" class="space-y-8">
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">Page Header</h2>
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-gray-300 mb-2">Subtitle</label>
                        <input type="text" name="subtitle" value="<%= page.subtitle || 'Testimonials' %>" required
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Content</label>
                        <input type="text" name="content" value="<%= page.content || '' %>" required
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                </div>
            </div>

            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">Client Logos (comma separated)</h2>
                <input type="text" name="logos" value="<%= (page.logos || []).join(', ') %>"
                    class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500"
                    placeholder="TechCorp, InnovateLab, DataMax, CloudFirst, NextGen">
            </div>

            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">Testimonials</h2>
                <p class="text-gray-400 text-sm mb-4">Edit each testimonial card. 3 testimonials max.</p>
                
                <% const testimonials = page.testimonials || [
                    { name: 'Sarah Ahmed', role: 'CEO, TechStart Inc.', initials: 'SA', gradientFrom: 'primary', gradientTo: 'primary-light', rating: 5, text: 'Great experience!' },
                    { name: 'Michael Khan', role: 'Founder, DeliveryHub', initials: 'MK', gradientFrom: 'purple-500', gradientTo: 'purple-400', rating: 5, text: 'Excellent work!' },
                    { name: 'Fatima Ali', role: 'CTO, FinanceFlow', initials: 'FA', gradientFrom: 'amber-500', gradientTo: 'amber-400', rating: 5, text: 'Highly recommended!' }
                ]; %>
                
                <% testimonials.forEach(function(t, index) { %>
                <div class="bg-gray-900 rounded-lg p-4 mb-4 border border-gray-700">
                    <h3 class="text-white font-medium mb-3">Testimonial <%= index + 1 %></h3>
                    <div class="grid md:grid-cols-2 gap-4 mb-3">
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Client Name</label>
                            <input type="text" name="name<%= index %>" value="<%= t.name %>"
                                class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Role/Company</label>
                            <input type="text" name="role<%= index %>" value="<%= t.role %>"
                                class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500">
                        </div>
                    </div>
                    <div class="grid md:grid-cols-3 gap-4 mb-3">
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Initials (2 chars)</label>
                            <input type="text" name="initials<%= index %>" value="<%= t.initials %>" maxlength="2"
                                class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Rating (1-5)</label>
                            <input type="number" name="rating<%= index %>" value="<%= t.rating %>" min="1" max="5"
                                class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-400 text-sm mb-1">Avatar Color</label>
                            <select name="gradientFrom<%= index %>" class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500">
                                <option value="primary" <%= t.gradientFrom === 'primary' ? 'selected' : '' %>>Teal</option>
                                <option value="purple-500" <%= t.gradientFrom === 'purple-500' ? 'selected' : '' %>>Purple</option>
                                <option value="amber-500" <%= t.gradientFrom === 'amber-500' ? 'selected' : '' %>>Amber</option>
                                <option value="blue-500" <%= t.gradientFrom === 'blue-500' ? 'selected' : '' %>>Blue</option>
                                <option value="green-500" <%= t.gradientFrom === 'green-500' ? 'selected' : '' %>>Green</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-gray-400 text-sm mb-1">Testimonial Text</label>
                        <textarea name="text<%= index %>" rows="3"
                            class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white text-sm focus:outline-none focus:border-teal-500"><%= t.text %></textarea>
                    </div>
                </div>
                <% }); %>
            </div>

            <div class="flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Save Changes
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>
</body>
</html>
