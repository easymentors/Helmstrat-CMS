<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings | Helmstrat CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0a0a0a; }
    </style>
</head>
<body class="min-h-screen text-gray-300">
    <header class="bg-gray-900 border-b border-gray-800 px-6 py-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/admin/dashboard" class="text-gray-400 hover:text-white">← Back to Dashboard</a>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-8">
        <h1 class="text-2xl font-bold text-white mb-8">Site Settings</h1>

        <% if (success) { %>
        <div class="bg-green-900/50 border border-green-700 text-green-300 px-4 py-3 rounded-lg mb-6">
            <%= success %>
        </div>
        <% } %>

        <form action="/admin/settings" method="POST" class="space-y-8">
            <!-- General Settings -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">General Settings</h2>
                <div class="space-y-4">
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-gray-300 mb-2">Site Name</label>
                            <input type="text" name="siteName" value="<%= settings.admin?.siteName || 'Helmstrat' %>"
                                class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-300 mb-2">Site Description</label>
                            <input type="text" name="siteDescription" value="<%= settings.admin?.siteDescription || '' %>"
                                class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">Contact Information</h2>
                <div class="space-y-4">
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-gray-300 mb-2">Email</label>
                            <input type="email" name="siteEmail" value="<%= settings.site?.email || '' %>"
                                class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-300 mb-2">Phone</label>
                            <input type="text" name="sitePhone" value="<%= settings.site?.phone || '' %>"
                                class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                        </div>
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Address</label>
                        <input type="text" name="siteAddress" value="<%= settings.site?.address || '' %>"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                </div>
            </div>

            <!-- Social Links -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <h2 class="text-lg font-semibold text-white mb-4">Social Media Links</h2>
                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-300 mb-2">Twitter URL</label>
                        <input type="url" name="twitter" value="<%= settings.site?.socialLinks?.twitter || '#' %>"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">LinkedIn URL</label>
                        <input type="url" name="linkedin" value="<%= settings.site?.socialLinks?.linkedin || '#' %>"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">GitHub URL</label>
                        <input type="url" name="github" value="<%= settings.site?.socialLinks?.github || '#' %>"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Instagram URL</label>
                        <input type="url" name="instagram" value="<%= settings.site?.socialLinks?.instagram || '#' %>"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                </div>
            </div>

            <!-- Email Settings -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-white">Email Configuration</h2>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="emailEnabled" <%= settings.email?.enabled ? 'checked' : '' %>
                            class="w-5 h-5 rounded bg-gray-700 border-gray-600 text-teal-500 focus:ring-teal-500">
                        <span class="text-gray-300">Enable Email</span>
                    </label>
                </div>
                <p class="text-gray-400 text-sm mb-4">
                    For Hostinger email, use: Host: smtp.hostinger.com, Port: 465, Secure: true
                </p>
                <div class="space-y-4">
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-gray-300 mb-2">SMTP Host</label>
                            <input type="text" name="emailHost" value="<%= settings.email?.host || 'smtp.hostinger.com' %>"
                                class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                        </div>
                        <div>
                            <label class="block text-gray-300 mb-2">SMTP Port</label>
                            <input type="number" name="emailPort" value="<%= settings.email?.port || 465 %>"
                                class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                        </div>
                    </div>
                    <div>
                        <label class="flex items-center gap-2 cursor-pointer mb-4">
                            <input type="checkbox" name="emailSecure" <%= settings.email?.secure !== false ? 'checked' : '' %>
                                class="w-5 h-5 rounded bg-gray-700 border-gray-600 text-teal-500 focus:ring-teal-500">
                            <span class="text-gray-300">Use SSL/TLS (Secure)</span>
                        </label>
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Email Address (Username)</label>
                        <input type="email" name="emailUser" value="<%= settings.email?.user || '' %>"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Email Password / App Password</label>
                        <input type="password" name="emailPassword" value="<%= settings.email?.password || '' %>"
                            placeholder="Enter your email password or app password"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 mb-2">Send Emails To</label>
                        <input type="email" name="emailTo" value="<%= settings.email?.to || '' %>"
                            class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-teal-500">
                    </div>
                </div>
            </div>

            <div class="flex space-x-4">
                <button type="submit" class="bg-teal-500 text-white px-8 py-3 rounded-lg hover:bg-teal-600 font-semibold">
                    Save Settings
                </button>
                <a href="/admin/dashboard" class="bg-gray-700 text-white px-8 py-3 rounded-lg hover:bg-gray-600 font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </main>
</body>
</html>
